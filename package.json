{
  "name": "sme-finance-ops-copilot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @finance-ops/web",
    "dev:web:clean": "npm run dev:clean --workspace @finance-ops/web",
    "dev:api": "npm run start:dev --workspace @finance-ops/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.46.2"
  }
}
