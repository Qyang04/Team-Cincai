DEBUG_MODE=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_ops?schema=public
REDIS_URL=redis://localhost:6379
QUEUE_MODE=inline
USE_MOCK_AI=true
USE_MOCK_AUTH=true
USE_MOCK_STORAGE=true
# Directory where POST /cases/:id/artifacts/upload stores bytes (defaults to ./.local-artifacts under the API cwd)
# LOCAL_ARTIFACT_DIR=C:/path/to/artifact-store
USE_MOCK_NOTIFICATIONS=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=finance-artifacts
ZAI_API_KEY=your-z-ai-api-key
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL_PRIMARY=glm-5.1
ZAI_MODEL_FAST=glm-5-turbo
