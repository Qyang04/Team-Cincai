 generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkflowType {
  EXPENSE_CLAIM
  PETTY_CASH_REIMBURSEMENT
  VENDOR_INVOICE_APPROVAL
  INTERNAL_PAYMENT_REQUEST
}

enum CaseStatus {
  DRAFT
  SUBMITTED
  INTAKE_PROCESSING
  AWAITING_REQUESTER_INFO
  POLICY_REVIEW
  AWAITING_APPROVAL
  AWAITING_APPROVER_INFO_RESPONSE
  FINANCE_REVIEW
  APPROVED
  REJECTED
  EXPORT_READY
  EXPORTING
  EXPORTED
  RECOVERABLE_EXCEPTION
  CLOSED
}

enum ActorType {
  SYSTEM
  REQUESTER
  APPROVER
  FINANCE_REVIEWER
  ADMIN
}

enum ArtifactType {
  RECEIPT
  INVOICE
  SCREENSHOT
  NOTE
  OTHER
}

model Case {
  id                  String               @id @default(uuid())
  workflowType        WorkflowType
  status              CaseStatus           @default(DRAFT)
  requesterId         String
  submittedNotes      String?
  assignedTo          String?
  priority            String               @default("MEDIUM")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  artifacts           Artifact[]
  extractionResults   ExtractionResult[]
  openQuestions       OpenQuestion[]
  policyResults       PolicyResult[]
  approvalMatrix      ApprovalMatrix?
  approvalTasks       ApprovalTask[]
  financeReviews      FinanceReview[]
  exportRecords       ExportRecord[]
  workflowTransitions WorkflowTransition[]
  auditEvents         AuditEvent[]
}

model Department {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       UserProfile[]
}

model UserProfile {
  id              String        @id
  email           String        @unique
  displayName     String
  roles           String[]
  departmentId    String?
  managerUserId   String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  department      Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager         UserProfile?  @relation("UserManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  directReports   UserProfile[] @relation("UserManager")
}

model ApprovalMatrix {
  id            String          @id @default(uuid())
  caseId         String          @unique
  status         String          @default("ACTIVE")
  routingReason  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  case           Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stages         ApprovalStage[]
}

model ApprovalStage {
  id               String         @id @default(uuid())
  matrixId         String
  stageNumber      Int
  mode             String         @default("SEQUENTIAL")
  dependencyType   String         @default("ALL_REQUIRED")
  label            String?
  status           String         @default("BLOCKED")
  requiredApprovals Int           @default(1)
  slaHours         Int?
  dueAt            DateTime?
  escalatesTo      String?
  escalatedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  matrix           ApprovalMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  tasks            ApprovalTask[]

  @@unique([matrixId, stageNumber])
}

model Artifact {
  id               String       @id @default(uuid())
  caseId           String
  type             ArtifactType @default(OTHER)
  source           String?
  filename         String
  mimeType         String?
  storageUri       String?
  extractedText    String?
  checksum         String?
  metadata         Json?
  processingStatus String       @default("PREPARED")
  errorMessage     String?
  uploadedAt       DateTime?
  processingStartedAt DateTime?
  processingCompletedAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  case             Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model WorkflowTransition {
  id         String     @id @default(uuid())
  caseId     String
  fromStatus CaseStatus
  toStatus   CaseStatus
  actorType  ActorType
  actorId    String?
  note       String?
  createdAt  DateTime   @default(now())
  case       Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id        String    @id @default(uuid())
  caseId    String
  eventType String
  actorType ActorType
  actorId   String?
  payload   Json
  createdAt DateTime  @default(now())
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model ExtractionResult {
  id          String   @id @default(uuid())
  caseId       String
  fieldsJson   Json
  confidence   Float
  provenance   Json
  modelMetadata Json?
  createdAt    DateTime @default(now())
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model OpenQuestion {
  id          String   @id @default(uuid())
  caseId       String
  question     String
  answer       String?
  status       String   @default("OPEN")
  source       String   @default("AI_INTAKE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model PolicyResult {
  id                  String   @id @default(uuid())
  caseId              String
  passed              Boolean
  warnings            Json
  blockingIssues      Json
  requiresFinanceReview Boolean @default(false)
  duplicateSignals    Json
  reconciliationFlags Json?
  approvalRequirement String?
  createdAt           DateTime @default(now())
  case                Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model ApprovalTask {
  id            String   @id @default(uuid())
  caseId         String
  stageId        String?
  approverId     String
  stageNumber    Int      @default(1)
  stageMode      String   @default("SEQUENTIAL")
  stageLabel     String?
  delegatedFrom  String?
  actingApproverId String?
  status         String   @default("PENDING")
  decision       String?
  decisionReason String?
  dueAt          DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stage          ApprovalStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
}

model FinanceReview {
  id          String   @id @default(uuid())
  caseId       String
  reviewerId   String?
  ownerId      String?
  outcome      String?
  reasonCategory String?
  codingDecision String?
  reconciliationStatus String?
  reconciledAmount Float?
  reconciledCurrency String?
  annotation   String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model ExportRecord {
  id            String   @id @default(uuid())
  caseId         String
  status         String   @default("READY")
  payload        Json
  connectorName  String   @default("mock-accounting-export")
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  case           Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model AdminSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
